{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "CMake Configure (Debug)",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build/debug",
                "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "windows": {
                "args": [
                    "-S", "${workspaceFolder}",
                    "-B", "${workspaceFolder}/build/debug",
                    "-G", "NMake Makefiles",
                    "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/vcpkg/scripts/buildsystems/vcpkg.cmake",
                    "-DCMAKE_BUILD_TYPE=Debug"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "CMake Configure (Release)",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build/release",
                "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "windows": {
                "args": [
                    "-S", "${workspaceFolder}",
                    "-B", "${workspaceFolder}/build/release",
                    "-G", "NMake Makefiles",
                    "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/vcpkg/scripts/buildsystems/vcpkg.cmake",
                    "-DCMAKE_BUILD_TYPE=Release"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "Build Debug (PgoEngine)",
            "dependsOn": "CMake Configure (Debug)",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build/debug",
                "--target", "PgoEngine"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "windows": {
                "problemMatcher": ["$msCompile"]
            },
            "group": "build",
            "detail": "Configures and builds the PgoEngine debug static library via CMake + vcpkg"
        },
        {
            "type": "shell",
            "label": "Build Release (PgoEngine)",
            "dependsOn": "CMake Configure (Release)",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build/release",
                "--target", "PgoEngine"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "windows": {
                "problemMatcher": ["$msCompile"]
            },
            "group": "build",
            "detail": "Configures and builds the PgoEngine release static library via CMake + vcpkg"
        },
        {
            "type": "shell",
            "label": "Build Debug (PgoCli)",
            "dependsOn": "CMake Configure (Debug)",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build/debug",
                "--target", "PgoCli"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "windows": {
                "problemMatcher": ["$msCompile"]
            },
            "group": "build",
            "detail": "Configures and builds the debug binary via CMake + vcpkg"
        },
        {
            "type": "shell",
            "label": "Build Release (PgoCli)",
            "dependsOn": "CMake Configure (Release)",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build/release",
                "--target", "PgoCli"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "windows": {
                "problemMatcher": ["$msCompile"]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Configures and builds the release binary via CMake + vcpkg"
        }
    ]
}
